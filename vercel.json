{
  "buildCommand": "npm install --legacy-peer-deps && npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "https://at-home-api.prometteur.in/admin/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://at-home-api.prometteur.in/api/:path*"
    }
  ]
}
